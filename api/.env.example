# BookARide API — Environment Variables
# Copy this file to .env.local for local development.
# In production, set these in the Vercel dashboard (Settings → Environment Variables).
# NEVER commit real values. This file contains placeholders only.

# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (required)
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret key for signing admin JWTs (required, use a long random string)
JWT_SECRET_KEY=replace-with-a-long-random-secret

# ─── Vapron Platform (CLAUDE.md 6f — Craig authorised 2026-06-10) ────────────
# Vapron provides ALL outbound email, the AI gateway, cron triggering, and OTP
# verification. Required for every email send and every AI call.
VAPRON_API_KEY=your_vapron_api_key_here
# Vapron API base URL (optional, defaults to https://api.vapron.ai)
VAPRON_BASE_URL=https://api.vapron.ai
# Vapron Verify service ID (required only for the admin-auth OTP endpoints)
VAPRON_VERIFY_SERVICE_ID=your_vapron_verify_service_id_here

# ─── Email (Mailgun — INBOUND ONLY) ──────────────────────────────────────────
# Vapron handles all SENDING (see above). Mailgun remains only for inbound
# support email: MX records + the route forwarding to /api/email/incoming.
# Keep these until Craig decides how inbound mail should flow (CLAUDE.md 6f).
MAILGUN_API_KEY=your_mailgun_api_key_here
# Mailgun receiving domain (e.g. mg.bookaride.co.nz)
MAILGUN_DOMAIN=mg.bookaride.co.nz
# Mailgun region: 'us' (default) or 'eu'
MAILGUN_REGION=us
# Sender address for no-reply emails (optional, defaults to noreply@bookaride.co.nz)
NOREPLY_EMAIL=noreply@bookaride.co.nz

# ─── Payments (Stripe) ───────────────────────────────────────────────────────
# Stripe secret key (required for checkout sessions)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
# Stripe publishable key (optional alias, falls back to STRIPE_SECRET_KEY)
STRIPE_API_KEY=your_stripe_api_key_here
# Stripe webhook signing secret (required to verify webhook signatures)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Google Maps / Places API key (required for address autocomplete + distance)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Google OAuth (admin login) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Public domain used for OAuth redirect URI (e.g. https://bookaride.co.nz)
PUBLIC_DOMAIN=https://bookaride.co.nz

# ─── Google Calendar ─────────────────────────────────────────────────────────
# JSON string of the Google service account credentials (optional)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Google Calendar ID to create booking events on
GOOGLE_CALENDAR_ID=primary

# ─── Notifications (addresses LOCKED by CLAUDE.md 6e) ───────────────────────
# Admin email for new booking notifications (optional, defaults to bookings@bookaride.co.nz)
BOOKINGS_NOTIFICATION_EMAIL=bookings@bookaride.co.nz
# Admin email for AI support escalations (optional, defaults to bookings@bookaride.co.nz)
ADMIN_EMAIL=bookings@bookaride.co.nz
# Contact form notification recipient (optional, defaults to bookings@bookaride.co.nz)
CONTACT_NOTIFICATION_EMAIL=bookings@bookaride.co.nz
# SEO daily report recipient (optional, defaults to BOOKINGS_NOTIFICATION_EMAIL)
SEO_REPORT_EMAIL=

# ─── Frontend ────────────────────────────────────────────────────────────────
# Public URL of the frontend (used for Stripe success/cancel redirect URLs)
FRONTEND_URL=https://bookaride.co.nz

# ─── Cron Jobs ───────────────────────────────────────────────────────────────
# Shared secret the Vapron cron job sends to /api/cron/daily-seo-agent, also
# used to authorise the one-time /api/admin/setup-vapron-cron endpoint
CRON_SECRET=replace-with-random-secret
