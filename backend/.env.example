# ============================================================
# BookARide Backend - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file — it is gitignored.
#
#   cp .env.example .env
#
# On Render: add these same variables under Environment > Env Vars
# ============================================================

# ── Database ─────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=bookaride

# ── Auth / JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string

# ── Google Maps (Distance Matrix, Directions, Places) ───────
GOOGLE_MAPS_API_KEY=

# ── Google OAuth (admin login via Google) ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Calendar (service account) ────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary

# ── Geoapify (address autocomplete & distance) ──────────────
GEOAPIFY_API_KEY=

# ── Stripe (payments) ───────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Afterpay ─────────────────────────────────────────────────
AFTERPAY_MERCHANT_ID=
AFTERPAY_SECRET_KEY=
AFTERPAY_ENV=sandbox

# ── PayPal ───────────────────────────────────────────────────
PAYPAL_ME_USERNAME=bookaridenz

# ── Twilio (SMS) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Mailgun (transactional email) ────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.bookaride.co.nz
SENDER_EMAIL=noreply@mg.bookaride.co.nz

# ── SMTP (fallback email) ───────────────────────────────────
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── iCloud (email inbox) ────────────────────────────────────
ICLOUD_EMAIL=
ICLOUD_APP_PASSWORD=

# ── Xero (accounting) ───────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=

# ── Aviation Stack (flight tracking) ─────────────────────────
AVIATIONSTACK_API_KEY=

# ── Admin / Notifications ───────────────────────────────────
ADMIN_EMAIL=bookings@bookaride.co.nz
ADMIN_PHONE=+6421743321
BOOKINGS_NOTIFICATION_EMAIL=bookings@bookaride.co.nz
NOREPLY_EMAIL=noreply@bookaride.co.nz

# ── App URLs ─────────────────────────────────────────────────
PUBLIC_DOMAIN=https://bookaride.co.nz
BACKEND_URL=

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Cron / Sync ──────────────────────────────────────────────
CRON_API_KEY=bookaride-cron-secret-2024
SYNC_SECRET_KEY=bookaride-sync-2024-secret
