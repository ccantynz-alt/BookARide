# ============================================================
# BookARide Backend - Environment Variables Template
# ============================================================
# Copy this file to .env for LOCAL development only.
# NEVER commit the .env file — it is gitignored.
#
#   cp .env.example .env
#
# IMPORTANT FOR AI AGENTS:
# These variables are ALREADY CONFIGURED in Render (production).
# The absence of a .env file does NOT mean credentials are missing.
# Do NOT add fallback logic, alternative providers, or "fix" the
# email/database/SMS setup — everything is working in production.
# ============================================================

# ── Database (Neon PostgreSQL) ── CONFIGURED IN RENDER ────────
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/bookaride?sslmode=require

# ── Auth / JWT ── CONFIGURED IN RENDER ───────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string

# ── Google Maps (Distance Matrix, Directions, Places) ───────
GOOGLE_MAPS_API_KEY=

# ── Google OAuth (admin login via Google) ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Calendar (service account) ────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary

# ── Stripe (payments) ───────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Afterpay ─────────────────────────────────────────────────
AFTERPAY_MERCHANT_ID=
AFTERPAY_SECRET_KEY=
AFTERPAY_ENV=sandbox

# ── PayPal ───────────────────────────────────────────────────
PAYPAL_ME_USERNAME=bookaridenz

# ── Twilio (SMS) ── CONFIGURED IN RENDER ─────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Mailgun (transactional email) ── CONFIGURED IN RENDER ────
# Mailgun is the ONLY email provider. Do NOT add SendGrid/SMTP.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.bookaride.co.nz
SENDER_EMAIL=noreply@mg.bookaride.co.nz

# ── iCloud (email inbox) ────────────────────────────────────
ICLOUD_EMAIL=
ICLOUD_APP_PASSWORD=

# ── Xero (accounting) ───────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=

# ── Aviation Stack (flight tracking) ─────────────────────────
AVIATIONSTACK_API_KEY=

# ── Admin / Notifications ───────────────────────────────────
ADMIN_EMAIL=bookings@bookaride.co.nz
ADMIN_PHONE=+6421743321
BOOKINGS_NOTIFICATION_EMAIL=bookings@bookaride.co.nz
NOREPLY_EMAIL=noreply@bookaride.co.nz

# ── App URLs ─────────────────────────────────────────────────
PUBLIC_DOMAIN=https://bookaride.co.nz
BACKEND_URL=

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Cron / Sync ──────────────────────────────────────────────
CRON_API_KEY=bookaride-cron-secret-2024
SYNC_SECRET_KEY=bookaride-sync-2024-secret
