# BookARide V2 Backend — Environment Variables
# Copy this to .env for local development, or set in Render dashboard for production.
# DO NOT commit real credentials to the repo.

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
JWT_SECRET_KEY=change-me-to-a-random-string

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Mailgun)
MAILGUN_API_KEY=key-...
MAILGUN_DOMAIN=bookaride.co.nz
NOREPLY_EMAIL=noreply@bookaride.co.nz
ADMIN_EMAIL=info@bookaride.co.nz

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# Google OAuth (admin login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App
PUBLIC_DOMAIN=https://bookaride.co.nz
PORT=10000
