# ═══════════════════════════════════════════════════════════════════
#  AI Ledger — Environment Variables (template only, no real secrets)
#
#  All credentials are configured in the hosting platform's dashboard
#  (e.g. Render).  Copy this file to .env for local development only.
# ═══════════════════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/ai_ledger

# ── Authentication / JWT ───────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── AI (Anthropic Claude) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# ── Email (Mailgun ONLY — no SMTP, no SendGrid) ───────────────────
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.example.com

# ── Payments (Stripe) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── Maps (Google — address validation) ─────────────────────────────
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Bank Feeds — US (Plaid) ───────────────────────────────────────
PLAID_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
PLAID_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Bank Feeds — AU / NZ (Basiq) ──────────────────────────────────
BASIQ_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Bank Feeds — UK (TrueLayer) ───────────────────────────────────
TRUELAYER_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
TRUELAYER_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Application ───────────────────────────────────────────────────
APP_NAME=AI Ledger
APP_URL=http://localhost:3000
